@model FixTechMVC.Models.Servico

@{
    ViewData["Title"] = "Detalhes do Serviço";
}

<h1>Detalhes do Serviço</h1>

<div class="card">
    <div class="card-body">
        <p><strong>Nome:</strong> @Model.Nome</p>
        <p><strong>Descrição:</strong> @Model.Descricao</p>
        <p><strong>Preço:</strong> R$ @Model.Preco.ToString("N2")</p>
    </div>
</div>

<br />

<a asp-action="Index" class="btn btn-secondary">Voltar</a>