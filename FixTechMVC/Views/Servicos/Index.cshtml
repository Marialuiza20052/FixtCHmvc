@model IEnumerable<FixTechMVC.Models.Servico>

@{
    ViewData["Title"] = "Gerenciamento de Serviços";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            🔧 Gerenciamento de Serviços
        </h2>

        <a asp-action="Create" class="btn btn-success">
            ➕ Novo Serviço
        </a>
    </div>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group">

            <input type="text"
                   name="pesquisar"
                   class="form-control"
                   placeholder="Pesquisar serviço pelo nome ou descrição..." />

            <button class="btn btn-primary" type="submit">
                🔍 Pesquisar
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Limpar
            </a>

        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            Nenhum serviço encontrado.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover table-bordered shadow">

            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Descrição</th>
                    <th>Preço</th>
                    <th width="320">Ações</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Id</td>

                        <td>@item.Nome</td>

                        <td>@item.Descricao</td>

                        <td>
                            @item.Preco.ToString("C")
                        </td>

                        <td class="text-center">

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm">
                                👁 Abrir
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-warning btn-sm">
                                ✏ Editar
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-danger btn-sm">
                                🗑 Excluir
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>
    }

</div>