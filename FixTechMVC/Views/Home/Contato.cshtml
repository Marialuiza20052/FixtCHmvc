@{
    ViewData["Title"] = "Contato";
}

<div class="container mt-5">

    <h1 class="text-primary fw-bold mb-4">📞 Contato</h1>

    <div class="row">

        <div class="col-md-6">
            <div class="card shadow mb-3">
                <div class="card-body">
                    <h4>📱 Telefone</h4>
                    <p>(61) 99999-9999</p>

                    <h4>📧 Email</h4>
                    <p>contato@fixtech.com</p>

                    <h4>📍 Endereço</h4>
                    <p>Luziânia - GO</p>

                    <h4>🕒 Atendimento</h4>
                    <p>Segunda a sexta, das 08h às 18h</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <h4>Envie uma mensagem</h4>

                    <input class="form-control mb-3" placeholder="Seu nome" />
                    <input class="form-control mb-3" placeholder="Seu email" />
                    <textarea class="form-control mb-3" rows="5" placeholder="Sua mensagem"></textarea>

                    <button class="btn btn-primary w-100">Enviar</button>
                </div>
            </div>
        </div>

    </div>

</div>
