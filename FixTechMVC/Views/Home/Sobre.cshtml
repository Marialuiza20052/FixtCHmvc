<@{
    ViewData["Title"] = "Sobre";
}

<div class="container mt-5">

    <h1 class="text-primary fw-bold mb-4">ℹ Sobre a FixTech</h1>

    <div class="card shadow mb-4">
        <div class="card-body">
            <h3>Quem somos</h3>
            <p>
                A FixTech é uma assistência técnica especializada em manutenção
                de celulares, notebooks e computadores.
            </p>
        </div>
    </div>

    <div class="row">

        <div class="col-md-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h4>🎯 Missão</h4>
                    <p>Oferecer serviços técnicos com qualidade, agilidade e confiança.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h4>👁 Visão</h4>
                    <p>Ser referência em assistência técnica e atendimento ao cliente.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h4>⭐ Valores</h4>
                    <p>Compromisso, transparência, responsabilidade e inovação.</p>
                </div>
            </div>
        </div>

    </div>

</div>